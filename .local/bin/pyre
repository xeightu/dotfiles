#!/usr/bin/env zsh

# ┌─── 1. Initialization & Imports ────────────────────────────────────────────┐

LIB_DIR="$HOME/.config/pyre/lib"

# [WARN] Critical modules: environment will fail to load if files are missing
source "$LIB_DIR/core.zsh"    || exit 1
source "$LIB_DIR/theme.zsh"   || exit 1
source "$LIB_DIR/layouts.zsh" || exit 1
source "$LIB_DIR/ui.zsh"      || exit 1


# ┌─── 2. System Verification ─────────────────────────────────────────────────┐

# Ensure core binaries (wofi, swww, jq, etc) are available before proceeding
check_dependencies


# ┌─── 3. Command Routing ─────────────────────────────────────────────────────┐

case "$1" in
    # Theme Management
    theme)
        case "$2" in
            set) apply_theme "$3" ;;
            *)   [[ -n "$2" ]] && apply_theme "$2" || show_theme_menu ;;
        esac
        ;;

    # Desktop Backgrounds
    wallpaper)
        case "$2" in
            select) show_wallpaper_menu ;;
            # [NOTE] Randomizes within the context of the currently active theme
            *)      _set_wallpaper_random ;;
        esac
        ;;

    # Workspace & Window Layouts
    layout)
        show_layout_menu
        ;;

    # System Maintenance
    reload)
        reload_services
        _notify "Pyre Engine" "Configurations reloaded." "system-reboot"
        ;;

    # Interactive Dashboard
    # [NOTE] Default entry point when no arguments are provided
    *)
        show_main_menu
        ;;
esac
