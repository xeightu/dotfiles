#!/usr/bin/env zsh
# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         HOURLY BRIGHTNESS SCHEDULE                         │
# └────────────────────────────────────────────────────────────────────────────┘

# --- Configuration ---

THRESHOLD=10                            # Hysteresis threshold (percent)
FADE_SPEED=0.05                         # Smoother transition (seconds per step)
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/brightness-manager.pid"

# [CONFIG] Hourly brightness map (Hour=Percentage).
# [INFO] Tailored for early winter sunsets in Estonia.
typeset -A SCHEDULE
SCHEDULE=(
    [06]=20 [07]=40 [08]=70             # Morning rise
    [09]=90 [10]=90 [11]=90             # Work hours (start)
    [12]=90 [13]=90 [14]=90             # Work hours (mid)
    [15]=90 [16]=80 [17]=70             # Early sunset phase
    [18]=60 [19]=50 [20]=45             # Evening relaxation
    [21]=40 [22]=30 [23]=20             # Pre-sleep wind down
    [00]=15 [01]=15 [02]=15             # Deep night
    [03]=10 [04]=10 [05]=10             # Deep night
)

LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/brightness_disabled"

# --- Helper Functions ---

# Check if brightnessctl is installed
if ! command -v brightnessctl >/dev/null 2>&1; then
    echo "Error: brightnessctl is not installed." >&2
    exit 1
fi

fade_brightness() {
    local target_pct=$1
    local speed=$2

    local max=$(brightnessctl m)
    local target_raw=$(( target_pct * max / 100 ))
    local current_raw=$(brightnessctl g)
    
    if (( current_raw == target_raw )); then return; fi

    # Determine step size in raw values for better precision
    local total_diff=$(( target_raw - current_raw ))
    local step_raw=$(( total_diff > 0 ? (max / 100) : -(max / 100) ))
    if (( step_raw == 0 )); then step_raw=$(( total_diff > 0 ? 1 : -1 )); fi

    while (( (step_raw > 0 && current_raw < target_raw) || (step_raw < 0 && current_raw > target_raw) )); do
        (( current_raw += step_raw ))
        
        # Clamp value
        if (( step_raw > 0 && current_raw > target_raw )) || (( step_raw < 0 && current_raw < target_raw )); then
            current_raw=$target_raw
        fi

        brightnessctl set "${current_raw}" &>/dev/null
        sleep $speed

        # Detect user interruption using raw values (tolerance: 5% of max)
        local check_raw=$(brightnessctl g)
        local diff=$(( check_raw > current_raw ? check_raw - current_raw : current_raw - check_raw ))
        if (( diff > (max * 0.05) )); then
            echo "User interrupted fade."
            return 1
        fi
    done
}

# --- Lock & PID Management ---

# Ensure only one instance is running
if [[ -f "$PID_FILE" ]]; then
    local old_pid=$(cat "$PID_FILE")
    if kill -0 "$old_pid" 2>/dev/null; then
        if [[ "$1" == "--force" ]]; then
            kill "$old_pid"
        else
            exit 0
        fi
    fi
fi
echo $$ > "$PID_FILE"
trap "rm -f $PID_FILE" EXIT

# --- Core Logic ---

if [[ -f "$LOCK_FILE" ]]; then exit 0; fi

integer HOUR_NOW=$(date +%H)
KEY_NOW=$(printf "%02d" $HOUR_NOW)
integer TARGET_NOW=${SCHEDULE[$KEY_NOW]:-50}

integer MAX=$(brightnessctl m 2>/dev/null) || exit 1
integer CURRENT_RAW=$(brightnessctl g 2>/dev/null)
integer CURRENT_PCT=$((CURRENT_RAW * 100 / MAX))

# [INFO] Force Mode Check
if [[ "$1" == "--force" ]]; then
    echo "Force mode: $KEY_NOW -> ${TARGET_NOW}%"
    fade_brightness $TARGET_NOW $FADE_SPEED
    exit 0
fi

# [INFO] Calculate deviation
integer diff_now=$(( CURRENT_PCT > TARGET_NOW ? CURRENT_PCT - TARGET_NOW : TARGET_NOW - CURRENT_PCT ))

if (( diff_now <= 2 )); then
    exit 0
elif (( diff_now <= THRESHOLD )); then
    echo "Adjusting brightness: ${CURRENT_PCT}% -> ${TARGET_NOW}%"
    fade_brightness $TARGET_NOW $FADE_SPEED
else
    # User override - do nothing until the next significant schedule change or --force
    exit 0
fi
