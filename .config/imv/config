[options]
scaling_mode = full
[binds]
n = next
p = prev
j = next
k = prev
<Left>  = prev
<Right> = next
<Home> = goto 1
<End>  = goto -1
a = scaling none
s = scaling shrink
z = scaling full
f = fullscreen
i = zoom 10
o = zoom -10
h = pan -50 0
l = pan 50 0
<Up>   = pan 0 -50
<Down> = pan 0 50
d = overlay
q = quit
