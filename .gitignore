# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       GLOBAL GITIGNORE (STRICT)                            │
# └────────────────────────────────────────────────────────────────────────────┘
# [CRITICAL] POLICY: DENY ALL (/*).
# We explicitly allow ONLY the configs we want to track.

/*

# ┌─── 1. Allowed Roots ───────────────────────────────────────────────────────┐

!/.gitignore
!/.gitmodules
!/LICENSE
!/README.md
!/.zshrc
!/.p10k.zsh
!/.mailmap
!/.local/
.local/*
!/.local/bin/
!/.local/bin/**

# ┌─── 2. Config Whitelist (The "Allow" List) ─────────────────────────────────┐
# [INFO] We open the gates only for specific folders in .config.

!/.config/
.config/*

# --- Shell & Core ---
!/.config/zsh/
!/.config/atuin/
!/.config/environment.d/
!/.config/mise/
!/.config/pyre/
# [INFO] Ignore state inside pyre
.config/pyre/state
.config/pyre/main_menu_last_choice

# --- Hyprland Ecosystem ---
!/.config/hypr/
!/.config/waybar/
!/.config/wofi/
!/.config/dunst/
!/.config/libinput-gestures.conf
!/.config/electron-flags.conf

# --- Terminals & Editors ---
!/.config/kitty/
!/.config/nvim/

# --- Apps & Tools ---
!/.config/fastfetch/
!/.config/imv/
!/.config/lazygit/
!/.config/lazydocker/
!/.config/ttyper/
!/.config/uair/
!/.config/gammastep/
!/.config/dooit/
!/.config/pupgui/
!/.config/sampler/
!/.config/glow/
.local/bin/spotdl
.config/spicetify/config-xpui.ini
.config/gtk-3.0/bookmarks
.config/btop/
!/.config/cava/

# --- System & GUI ---
!/.config/gtk-3.0/
!/.config/gtk-4.0/
!/.config/qt6ct/
!/.config/Kvantum/
!/.config/nwg-look/
!/.config/lxqt/

# ┌─── 3. Surgical Exceptions (Partial Allows) ────────────────────────────────┐
# [INFO] Folders where we want config files, but NOT the heavy data/bloat.

# --- Clipse (Clipboard) ---
# [INFO] Block the binary DB, allow config JSONs.
!/.config/clipse/
.config/clipse/*
!/.config/clipse/*.json
.config/clipse/clipboard_history.json
!/.config/clipse/*.png

# --- Spicetify ---
# [INFO] Block backups/binaries, allow CSS and ini.
!/.config/spicetify/
.config/spicetify/*
!/.config/spicetify/*.css
!/.config/spicetify/*.ini

# --- Systemd ---
# [INFO] Block symlinks (.wants), allow real units.
!/.config/systemd/user/
.config/systemd/user/*.wants/
.config/systemd/user/playerctld.service

# ┌─── 4. Global Noise Filters (Double Check) ─────────────────────────────────┐
# [INFO] Safety net in case an allowed folder contains junk or secrets.

*.log
*.tmp
*.bak
*.swp
*~
.DS_Store
__pycache__/
node_modules/

# --- Secrets ---
.config/Bitwarden/
.config/keepassxc/
.config/Proton/
*.kdbx
id_rsa
id_ed25519
.zsh_history
.bash_history
.config/spicetify/config-xpui.ini
