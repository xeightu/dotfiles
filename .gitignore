# ┌────────────────────────────────────────────────────────────────────────────┐
# │                            GLOBAL GITIGNORE                                │
# └────────────────────────────────────────────────────────────────────────────┘

# ┌─── Core & temporary Files ─────────────────────────────────────────────────┐

# --- Generic Patterns ---
# [INFO] Temporary files, logs, and system junk.
*.log
*.log.old
*.bak
*.old
*.tmp
*.swp
*.swo
*~
*.lock
.DS_Store

# --- Specific Exceptions ---
# [INFO] Force track specific files that match ignore patterns above.
!/.config/hypr/hyprlock.conf

# ┌─── Security & Secrets ─────────────────────────────────────────────────────┐
# [CRITICAL] Never track these folders. They contain keys, passwords, or tokens.

.ssh/
.gnupg/
.config/Bitwarden/
.config/keepassxc/
.config/Proton/
.config/Proton Mail/
.config/keyd/
*.kdbx

# ┌─── System State & Cache ───────────────────────────────────────────────────┐
# [INFO] Auto-generated files that are machine-specific or binary caches.

# --- Cache & Pywal ---
.cache/
.config/wal/
.config/cava/shaders/
.config/cava/themes/

# --- Desktop Environment State ---
.config/dconf/
.config/gtk-3.0/bookmarks
.config/gtk-4.0/assets
.config/mimeapps.list
.config/user-dirs.dirs
.config/user-dirs.locale
.config/xsettingsd/
.config/xdg-desktop-portal/
.config/xfce4/
.config/nwg-look/

# --- Audio & Hardware ---
.config/pavucontrol.ini
.config/pulse/
.config/ryzen-controller/
.config/cpupower_gui/

# ┌─── Heavy Applications (Electron/Web) ──────────────────────────────────────┐
# [INFO] Browsers, Discord, and apps with huge cache/state folders.

# --- Browsers ---
.config/torbrowser/
.config/vivaldi/
.config/google-chrome/
.config/chromium/
.config/microsoft-edge*/

# --- Communication ---
.config/discord/
.config/vesktop/
.config/Vencord/
.config/Slack/
.config/Telegram Desktop/

# --- Editors (GUI) ---
.config/Code/
.config/VSCodium/
.config/obsidian/
.config/obsidian_backup/
.config/LM Studio/

# --- Media & Streaming ---
.config/spotify/
.config/spicetify/CustomApps/
.config/spicetify/Themes/
.config/spicetify/config-xpui.ini
.config/obs-studio/
.config/vlc/

# ┌─── Development & Languages ────────────────────────────────────────────────┐

.config/go/
.cargo/
.npm/
.yarn/
.bundle/
.venv/
__pycache__/
node_modules/

# ┌─── Games & Mods ───────────────────────────────────────────────────────────┐

.config/unity3d/
.config/r2modman/
.config/r2modmanPlus-local/
.config/HKModInstaller/
.config/heroic/
.config/lutris/
.config/steam/

# ┌─── Specific Config Exclusions ─────────────────────────────────────────────┐
# [INFO] Configs that exist but you chose NOT to track (Machine local).

.config/pyre/main_menu_last_choice
.config/btop/btop.conf
.config/fastfetch/presets/
.config/cliphist/
.config/clipse/
.config/pyre/state
.config/autostart/steam.desktop

# --- Full Folder Ignores ---
# [NOTE] Check if you want to track these later.
.config/yazi/
.config/zellij/
.config/arkrc
.config/macchina/
.config/qalculate/
.config/thunar/
.config/Thunar/
.config/viewnior/
