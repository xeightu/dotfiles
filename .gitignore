# [WARN] Default deny-all policy to ensure only explicit configs are tracked
/*


# ┌─── 1. Repository & Shell ──────────────────────────────────────────────────┐

# Core repo metadata
!/.gitignore
!/.gitmodules
!/.mailmap
!/README.md
!/LICENSE

# Shell initialization
!/.zshrc
!/.p10k.zsh

# Local scripts
!/.local/
.local/*
!/.local/bin/
!/.local/bin/**

# Apps and symlinks
.local/bin/spotdl
.local/bin/whisper
.local/bin/obsidian
.local/bin/copyparty-sfx.py


# ┌─── 2. Desktop Environment ─────────────────────────────────────────────────┐

!/.config/
.config/*

# Hyprland Ecosystem
!/.config/hypr/
!/.config/waybar/
!/.config/rofi/
!/.config/dunst/
!/.config/mako/
!/.config/libinput-gestures.conf

# Theme & GUI Toolkits
!/.config/gtk-3.0/
!/.config/gtk-4.0/
!/.config/qt6ct/
!/.config/Kvantum/
!/.config/nwg-look/
!/.config/lxqt/

# [NOTE] Persistence & State exclusions
.config/gtk-3.0/bookmarks
!/.config/electron-flags.conf


# ┌─── 3. Development & Productivity ──────────────────────────────────────────┐

# Terminals & Editors
!/.config/kitty/
!/.config/nvim/

# Runtimes & History
!/.config/zsh/
!/.config/atuin/
!/.config/mise/
!/.config/environment.d/

# CLI Utilities
!/.config/fastfetch/
!/.config/lazygit/
!/.config/lazydocker/
!/.config/mise/
!/.config/uair/
!/.config/ttyper/
!/.config/gammastep/


# ┌─── 4. Specialized App Handling ────────────────────────────────────────────┐

# Pyre Engine
!/.config/pyre/
!/.config/pyre/lib/
!/.config/pyre/layouts/
.config/pyre/state
.config/pyre/main_menu_last_choice

# Media & Visuals
!/.config/cava/
.config/cava/shaders/
!/.config/imv/
/.config/pupgui/

# Spicetify (Spotify)
!/.config/spicetify/
.config/spicetify/*
!/.config/spicetify/*.css
!/.config/spicetify/*.ini

# Systemd Units
!/.config/systemd/user/
.config/systemd/user/*.wants/
.config/systemd/user/playerctld.service


# ┌─── 5. System Protection & Security ────────────────────────────────────────┐

# [NOTE] Global noise and cache filters
*.log
*.tmp
*.bak
*.zwc
*.swp
*~
.DS_Store
__pycache__/
node_modules/
.config/btop/

# [WARN] Critical: Security vaults and private credentials
.config/Bitwarden/
.config/keepassxc/
.config/Proton/
*.kdbx
id_rsa
id_ed25519

# [WARN] Prevent leakage of shell history (tokens, passwords)
.zsh_history
.bash_history
.config/spicetify/config-xpui.ini
